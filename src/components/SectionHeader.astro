---
interface Props {
  number: number;
  title: string;
  leftLabel?: string;
  rightLabel?: string;
  leftLabelClass?: string; // controls first sub-label column width; default 'w-40'
}

const {
  number,
  title,
  leftLabel = 'Section',
  rightLabel = 'Description',
  leftLabelClass = 'w-40',
} = Astro.props;
---

<!-- Top rule -->
<hr class="border-t border-black w-full" />

<!-- Header row: index badge | TITLE | bullet -->
<div class="editorial-grid items-start">
  <!-- Number block — compact on mobile, ~150 px on desktop -->
  <div class="pt-6 pb-2 md:pt-8 md:pb-10">
    <div class="section-badge bg-black inline-flex items-center justify-center">
      <span class="font-display font-bold text-white leading-none">
        {number}.
      </span>
    </div>
  </div>
  <!-- Title + bullet -->
  <div class="flex items-start justify-between gap-4 pt-0 pb-8 md:pt-8 md:pb-10">
    <h2 class="font-display font-normal text-black leading-none tracking-tight"
        style="font-size: clamp(2.2rem, 6vw, 7rem); letter-spacing: -0.05em;">
      {title}
    </h2>
    <span class="w-2 h-2 rounded-full bg-black mt-4 flex-shrink-0 hidden md:block"></span>
  </div>
</div>

<style>
  .section-badge {
    padding: 0.6rem 1rem;
    min-width: 5rem;
  }
  .section-badge span {
    font-size: 1.75rem;
  }
  @media (min-width: 768px) {
    .section-badge {
      padding: 1rem 1.25rem;
      min-width: 9rem;
    }
    .section-badge span {
      font-size: clamp(2.5rem, 4vw, 3.75rem);
    }
  }
</style>

<!-- Sub-label row (omitted when both labels are empty) -->
{(leftLabel || rightLabel) && (
  <div class="editorial-grid pb-3">
    <div class="hidden md:block"></div>
    <div class="flex gap-0">
      <span class={`col-label flex-shrink-0 ${leftLabelClass}`}>{leftLabel}</span>
      <span class="col-label">{rightLabel}</span>
    </div>
  </div>
)}

<!-- Bottom rule -->
<hr class="border-t border-black/20 w-full" />
