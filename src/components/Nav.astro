---
const navLinks = [
  { label: 'Platform',  href: '/platform' },
  { label: 'Fund',      href: '/fund' },
  { label: 'Ecosystem', href: '/ecosystem' },
  { label: 'Team',      href: '/team' },
  { label: 'Contact',   href: '/contact' },
];
---

<!-- ─── Fixed nav bar ──────────────────────────────────────── -->
<header class="fixed top-0 inset-x-0 z-40 bg-cream border-b border-black/10">
  <div class="section-container">
    <nav class="flex items-center justify-between h-12">
      <a href="/" class="flex items-center hover:opacity-70 transition-opacity">
        <img src="/logo.png" alt="Parinama" class="h-7 w-auto" />
      </a>
      <div class="flex items-center gap-6">
        <a href="/contact" class="text-xs font-display font-medium text-black/50 hover:text-black transition-colors tracking-wide hidden md:block">
          Investor Enquiry →
        </a>
        <!-- Hamburger — two bars, morphs to X when open -->
        <button id="menu-btn" class="relative flex flex-col justify-center gap-[5px] w-5 h-5" aria-label="Open menu" aria-expanded="false">
          <span id="bar-t" class="block w-full h-px bg-black transition-all duration-200 origin-center"></span>
          <span id="bar-b" class="block w-full h-px bg-black transition-all duration-200 origin-center"></span>
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- ─── Full-screen menu overlay ─────────────────────────────
     Slides DOWN from behind the nav bar.
     ease-in: slow start → fast finish, no bounce.
──────────────────────────────────────────────────────────── -->
<div
  id="mobile-menu"
  class="fixed inset-0 bg-forest z-50"
  style="transform: translateY(-100%); pointer-events: none; will-change: transform;"
  aria-hidden="true"
>
  <div class="h-full flex flex-col">

    <!-- Menu header: identical layout to nav bar so X sits where hamburger was -->
    <div class="section-container flex-shrink-0 border-b border-white/10">
      <div class="flex items-center justify-between h-12">
        <a href="/" class="flex items-center opacity-40">
          <img src="/logo.png" alt="Parinama" class="h-7 w-auto" />
        </a>
        <div class="flex items-center gap-6">
          <span class="text-xs font-display font-medium text-white/0 hidden md:block">
            Investor Enquiry →
          </span>
          <!-- Close button — same position as hamburger -->
          <button id="close-btn" class="relative flex flex-col justify-center gap-[5px] w-5 h-5" aria-label="Close menu">
            <span class="block w-full h-px bg-white rotate-45  translate-y-[3px]  transition-all duration-200 origin-center"></span>
            <span class="block w-full h-px bg-white -rotate-45 -translate-y-[3px] transition-all duration-200 origin-center"></span>
          </button>
        </div>
      </div>
    </div>

    <!-- Nav links — full-bleed borders, text at padding edge on mobile, 25% offset on md+ -->
    <nav class="flex-1 flex flex-col justify-center">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          class="menu-item group block border-b border-white/15"
          style="opacity: 0; transform: translateY(10px);"
          data-i={i}
        >
          <div class="menu-link-inner px-6 md:px-12 lg:px-16">
            <div class="hidden md:block"></div>
            <div class="flex items-center justify-between py-4 md:py-7">
              <span
                class="font-display font-normal text-white leading-none tracking-tight"
                style="font-size: clamp(2.5rem, 4.5vw, 4rem);"
              >
                {link.label}
              </span>
              <span class="text-white/0 group-hover:text-white/60 transition-colors duration-200 text-xl md:text-3xl font-sans">
                →
              </span>
            </div>
          </div>
        </a>
      ))}
    </nav>

    <!-- Footer -->
    <div class="section-container flex-shrink-0 border-t border-white/10 py-6">
      <p class="text-xs font-sans text-white/30 mb-1 uppercase tracking-widest">Contact</p>
      <a href="mailto:investors@parinama.com" class="text-sm font-display font-medium text-white/60 hover:text-white transition-colors">
        investors@parinama.com
      </a>
    </div>

  </div>
</div>

<style>
  /* Menu link layout — single col mobile, 1fr/3fr desktop */
  .menu-link-inner { display: block; }
  @media (min-width: 768px) {
    .menu-link-inner {
      display: grid;
      grid-template-columns: 1fr 3fr;
      gap: 0;
    }
  }

  /* Ease-in: starts slow, finishes fast — no overshoot, no bounce */
  #mobile-menu {
    transition: transform 0.45s cubic-bezier(0.4, 0, 1, 1);
  }
  #mobile-menu.is-open {
    transform: translateY(0) !important;
    pointer-events: auto !important;
  }

  /* Stagger items in after panel arrives */
  .menu-item {
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  #mobile-menu.is-open .menu-item {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }
  #mobile-menu.is-open .menu-item:nth-child(1) { transition-delay: 0.20s; }
  #mobile-menu.is-open .menu-item:nth-child(2) { transition-delay: 0.26s; }
  #mobile-menu.is-open .menu-item:nth-child(3) { transition-delay: 0.32s; }
  #mobile-menu.is-open .menu-item:nth-child(4) { transition-delay: 0.38s; }
  #mobile-menu.is-open .menu-item:nth-child(5) { transition-delay: 0.44s; }
</style>

<script>
  const btn      = document.getElementById('menu-btn');
  const closeBtn = document.getElementById('close-btn');
  const menu     = document.getElementById('mobile-menu');

  function open() {
    menu?.classList.add('is-open');
    menu?.setAttribute('aria-hidden', 'false');
    btn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    menu?.classList.remove('is-open');
    menu?.setAttribute('aria-hidden', 'true');
    btn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', open);
  closeBtn?.addEventListener('click', close);
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
</script>
