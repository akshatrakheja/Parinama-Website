---
const year = new Date().getFullYear();
---

<footer class="bg-black text-white border-t border-white/10">
  <div class="section-container">

    <!-- Top section -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 divide-y md:divide-y-0 md:divide-x divide-white/10 py-12 md:py-16">

      <!-- Brand -->
      <div class="pb-8 md:pb-0 md:pr-10">
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-6 h-6 bg-white flex items-center justify-center">
            <span class="text-black text-xs font-display font-bold">P</span>
          </div>
          <span class="font-display font-bold text-base text-white tracking-tight">Parinama</span>
        </div>
        <p class="text-white/50 text-sm font-sans leading-relaxed mb-1">
          India's first full-stack climate platform.
        </p>
        <p class="text-white/25 text-xs font-sans uppercase tracking-widest">
          AIF &middot; Advisory &middot; Ecosystem
        </p>
      </div>

      <!-- Links -->
      <div class="py-8 md:py-0 md:px-10">
        <h3 class="text-xs font-display font-semibold uppercase tracking-widest text-white/30 mb-5">Navigate</h3>
        <ul class="space-y-3">
          {[
            { label: 'Platform Overview', href: '/platform' },
            { label: 'The Fund',          href: '/fund' },
            { label: 'Ecosystem',         href: '/ecosystem' },
            { label: 'Team',              href: '/team' },
            { label: 'Contact',           href: '/contact' },
          ].map(l => (
            <li>
              <a href={l.href} class="text-sm font-sans text-white/50 hover:text-white transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="pt-8 md:pt-0 md:pl-10">
        <h3 class="text-xs font-display font-semibold uppercase tracking-widest text-white/30 mb-5">Contact</h3>
        <a
          href="mailto:investors@parinama.com"
          class="text-sm font-sans text-gold-DEFAULT hover:text-gold-light transition-colors block mb-6"
        >
          investors@parinama.com
        </a>
        <a href="/contact" class="btn-ghost text-xs px-4 py-2.5">
          Investor Enquiry →
        </a>
      </div>
    </div>

    <!-- Legal disclaimer -->
    <div class="border-t border-white/10 py-6">
      <p class="text-xs font-sans text-white/30 leading-relaxed max-w-3xl mb-3">
        <span class="text-white/50 font-semibold">Disclaimer:</span> For informational purposes only. Does not constitute an offer to buy or sell securities. Subject to SEBI AIF Regulations 2012.
      </p>
      <p class="text-xs font-sans text-white/20">
        &copy; {year} Parinama Group. All rights reserved.
      </p>
    </div>

  </div>
</footer>
