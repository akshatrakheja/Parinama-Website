---
interface Props {
  number: number;
  title: string;
  leftLabel?: string;
  rightLabel?: string;
  leftLabelClass?: string; // controls first sub-label column width; default 'w-40'
}

const {
  number,
  title,
  leftLabel = 'Section',
  rightLabel = 'Description',
  leftLabelClass = 'w-40',
} = Astro.props;
---

<!-- Top rule -->
<hr class="border-t border-black w-full" />

<!-- Header row: fixed-width index badge | TITLE | bullet -->
<div class="editorial-grid items-start">
  <!-- Number block — ~150 px wide, self-contained, top-anchored -->
  <div class="pt-6 pb-8 md:pt-8 md:pb-10">
    <div class="bg-black inline-flex items-center justify-center px-5 py-4"
         style="min-width: 9rem;">
      <span class="font-display font-bold text-white leading-none"
            style="font-size: clamp(2.5rem, 4vw, 3.75rem);">
        {number}.
      </span>
    </div>
  </div>
  <!-- Title + bullet -->
  <div class="flex items-start justify-between gap-4 pt-6 pb-8 md:pt-8 md:pb-10">
    <h2 class="font-display font-normal text-black leading-none tracking-tight leading-none"
        style="font-size: clamp(3rem, 6vw, 7rem); letter-spacing: -0.05em;">
      {title}
    </h2>
    <span class="w-2 h-2 rounded-full bg-black mt-4 flex-shrink-0"></span>
  </div>
</div>

<!-- Sub-label row -->
<div class="editorial-grid pb-3">
  <div></div>
  <div class="flex gap-0">
    <span class={`col-label flex-shrink-0 ${leftLabelClass}`}>{leftLabel}</span>
    <span class="col-label">{rightLabel}</span>
  </div>
</div>

<!-- Bottom rule -->
<hr class="border-t border-black/20 w-full" />
