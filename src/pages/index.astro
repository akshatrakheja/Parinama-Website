---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatStrip from '../components/StatStrip.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CardGrid from '../components/CardGrid.astro';
import TeamPlaceholder from '../components/TeamPlaceholder.astro';

const platformCards = [
  {
    title: 'Venture Builder',
    tagline: 'Start the companies India needs.',
    detail: '2% management fee + 20% carry, Impact-NAV accounting.',
    metric: '3 active investments',
    icon: '⚡',
    href: '/platform',
  },
  {
    title: 'Advisory & JV',
    tagline: 'Engineer transition pathways for corporates, sovereigns, DFIs.',
    detail: 'Retainer + success fee + JV equity share.',
    metric: '2 engaged, 3 near close',
    icon: '🤝',
    href: '/platform',
  },
  {
    title: 'Ecosystem Architect',
    tagline: 'Convene ICIC, deliver via ICIITE.',
    detail: 'Philanthropic + GoI grant funding.',
    metric: 'ICIC + ICIITE in pilot',
    icon: '🌐',
    href: '/platform',
  },
];

const moatCards = [
  { title: 'Full-Stack Platform',    tagline: 'End-to-end: capital → advisory → ecosystem.', icon: '◈' },
  { title: 'Institutional Pedigree', tagline: 'Operators and allocators, not just advisors.',  icon: '🏛' },
  { title: 'Sovereign Signal',       tagline: 'Aligned with national climate transition agenda.', icon: '⚑' },
  { title: 'Builder-LP Duality',     tagline: 'We build companies and invest in them.',       icon: '⟳' },
  { title: 'Blended Capital',        tagline: 'Public + private + philanthropic stacks.',     icon: '⊕' },
  { title: 'Impact-NAV',             tagline: 'Proprietary impact-adjusted valuation model.', icon: '◎' },
];

const teamMembers = [
  { name: 'Guneet Banga',     role: 'Founding Partner' },
  { name: 'Rajiv P Kapahi',   role: 'Founding Partner' },
  { name: 'Amarjeet Makhija', role: 'Founding Partner' },
  { name: 'Audrey N. Selian', role: 'Advisor' },
];
---

<BaseLayout>
  <!-- 1. HERO -->
  <section class="relative min-h-screen flex items-center pt-16 overflow-hidden bg-charcoal">
    <!-- Background pattern -->
    <div class="absolute inset-0 opacity-20" aria-hidden="true">
      <div class="absolute inset-0 bg-gradient-to-br from-forest-900 via-charcoal to-sky-dark"></div>
      <!-- Geometric accent lines -->
      <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
        <defs>
          <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
            <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="0.5" opacity="0.3"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)"/>
      </svg>
    </div>

    <!-- Hero content -->
    <div class="relative section-container py-20 md:py-28 z-10">
      <!-- Chip -->
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-lime-DEFAULT animate-pulse"></span>
        <span class="text-xs font-medium text-white/80 tracking-wide">SEBI Cat-II AIF · First close Q4 2026</span>
      </div>

      <div class="max-w-4xl">
        <h1 class="font-serif text-4xl md:text-6xl lg:text-7xl font-bold text-white leading-tight mb-6">
          India's climate<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-lime-DEFAULT to-sky-brand">
            transformation
          </span><br/>
          is the investment.
        </h1>

        <p class="text-lg md:text-xl text-white/70 font-medium mb-3 max-w-2xl leading-relaxed">
          India's first full-stack climate platform — AIF · Advisory · Ecosystem.
        </p>
        <p class="text-base text-white/50 mb-10 max-w-xl leading-relaxed">
          India's climate transformation is underway. This is the entry point.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="btn-primary">
            Investor Enquiry
          </a>
          <a href="/platform" class="btn-ghost">
            Explore the Platform
          </a>
        </div>
      </div>

      <!-- Hero visual placeholder -->
      <div class="hidden lg:block absolute right-0 top-1/2 -translate-y-1/2 w-2/5 h-96 mr-8">
        <div class="w-full h-full rounded-2xl bg-white/5 border border-dashed border-white/20 flex flex-col items-center justify-center gap-3">
          <svg class="w-12 h-12 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span class="text-xs text-white/30 font-medium">Hero image — placeholder</span>
          <span class="text-xs text-white/20">Full-bleed image + dark overlay</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. STAT STRIP -->
  <StatStrip />

  <!-- 3. PLATFORM OVERVIEW -->
  <section class="section-py bg-cream">
    <div class="section-container">
      <SectionHeading
        eyebrow="The Platform"
        heading="Three businesses. One goal."
        subheading="A platform — not a portfolio. Each pillar reinforces the others."
      />
      <CardGrid cards={platformCards} columns={3} />
    </div>
  </section>

  <!-- 4. SIX MOATS -->
  <section class="section-py bg-forest">
    <div class="section-container">
      <SectionHeading
        eyebrow="Why Parinama"
        heading="Six structural moats."
        subheading="Built-in advantages that compound over time. Full detail on the Platform page."
        theme="dark"
      />
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        {moatCards.map(card => (
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-5 border border-white/10 hover:bg-white/15 transition-colors">
            <div class="text-2xl mb-3">{card.icon}</div>
            <h3 class="font-serif font-semibold text-white text-base mb-1">{card.title}</h3>
            <p class="text-sm text-white/60 leading-snug">{card.tagline}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/platform" class="btn-ghost text-sm">
          Full platform detail →
        </a>
      </div>
    </div>
  </section>

  <!-- 5. FUND SNAPSHOT -->
  <section class="section-py bg-white">
    <div class="section-container">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-forest mb-3">The Fund</p>
            <h2 class="font-serif text-3xl md:text-4xl font-bold text-charcoal mb-6 leading-tight">
              Purpose-built for India's climate transition.
            </h2>
            <ul class="space-y-4">
              {[
                { label: 'Structure', value: 'SEBI Cat-II AIF + Singapore VCC feeder + evergreen' },
                { label: 'Target size', value: '$150M (hard cap $200M TBD)' },
                { label: 'First close', value: 'Q4 2026 · $50M anchor committed' },
                { label: 'Ticket size', value: '$1M – $10M per LP' },
                { label: 'Strategy', value: 'Climate-only · Pre-seed → Series A' },
              ].map(item => (
                <li class="flex gap-4 items-start">
                  <span class="text-forest mt-1">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                  </span>
                  <div>
                    <span class="text-xs font-semibold uppercase tracking-wide text-charcoal/40 block mb-0.5">{item.label}</span>
                    <span class="text-sm text-charcoal/80">{item.value}</span>
                  </div>
                </li>
              ))}
            </ul>
            <div class="mt-8">
              <a href="/fund" class="btn-primary text-sm">
                Full fund details →
              </a>
            </div>
          </div>
          <div class="bg-forest/5 rounded-2xl p-8 border border-forest/10">
            <div class="text-center mb-6">
              <div class="font-serif text-5xl font-bold text-forest mb-1">$150M</div>
              <div class="text-sm text-charcoal/50">Target Fund Size</div>
            </div>
            <div class="space-y-3">
              {[
                { label: 'Blended Net IRR', value: '15–20%', sub: 'USD, post-fees (target)' },
                { label: 'Hard Cap', value: '$200M', sub: 'TBD, subject to SEBI' },
                { label: 'Anchor', value: '$50M', sub: 'First close target' },
              ].map(item => (
                <div class="flex justify-between items-center py-3 border-b border-forest/10 last:border-0">
                  <div>
                    <div class="text-xs text-charcoal/40 uppercase tracking-wide mb-0.5">{item.label}</div>
                    <div class="text-xs text-charcoal/30">{item.sub}</div>
                  </div>
                  <div class="font-serif font-bold text-lg text-forest">{item.value}</div>
                </div>
              ))}
            </div>
            <p class="text-xs text-charcoal/30 mt-4 text-center leading-relaxed">
              For informational purposes only. Subject to SEBI AIF Regulations 2012.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. ECOSYSTEM PREVIEW -->
  <section class="section-py bg-cream">
    <div class="section-container">
      <SectionHeading
        eyebrow="The Ecosystem"
        heading="Convene. Deliver. Scale."
        subheading="Two interlocking bodies — ICIC for governance, ICIITE for delivery. Backed by the 4P architecture."
      />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <div class="bg-white rounded-2xl p-8 border border-forest/10">
          <div class="w-12 h-12 rounded-xl bg-forest text-white flex items-center justify-center text-xl mb-5 font-serif font-bold">I</div>
          <h3 class="font-serif text-xl font-bold text-charcoal mb-3">ICIC</h3>
          <p class="text-charcoal/60 text-sm leading-relaxed mb-4">
            India Climate Investors Council — the convening table. Investor-led governance with 8 active working groups.
          </p>
          <div class="flex flex-wrap gap-2">
            {['Investor-led', 'Governance body', '8 working groups'].map(tag => (
              <span class="text-xs bg-forest/5 text-forest rounded-full px-3 py-1 border border-forest/10">{tag}</span>
            ))}
          </div>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-forest/10">
          <div class="w-12 h-12 rounded-xl bg-sky-brand/20 text-sky-dark flex items-center justify-center text-xl mb-5 font-serif font-bold">I</div>
          <h3 class="font-serif text-xl font-bold text-charcoal mb-3">ICIITE</h3>
          <p class="text-charcoal/60 text-sm leading-relaxed mb-4">
            The delivery engine: accelerator → FOAK → blended finance → scale → MRV. End-to-end pipeline.
          </p>
          <div class="flex flex-wrap gap-2">
            {['Accelerator', 'FOAK financing', 'Blended finance', 'MRV'].map(tag => (
              <span class="text-xs bg-sky-brand/10 text-sky-dark rounded-full px-3 py-1 border border-sky-brand/20">{tag}</span>
            ))}
          </div>
        </div>
      </div>
      <div class="bg-forest/5 rounded-2xl p-6 border border-forest/10">
        <p class="text-sm text-charcoal/60 text-center mb-4 font-medium">Backed by the 4P Architecture</p>
        <div class="flex flex-wrap justify-center gap-4 md:gap-8">
          {['Public', 'Private', 'Philanthropic', 'People'].map((p, i) => (
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-forest/40"></span>
              <span class="text-sm font-semibold text-charcoal/70">{p}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="text-center mt-8">
        <a href="/ecosystem" class="btn-secondary text-sm">
          Explore the ecosystem →
        </a>
      </div>
    </div>
  </section>

  <!-- 7. TEAM PREVIEW -->
  <section class="section-py bg-white">
    <div class="section-container">
      <SectionHeading
        eyebrow="The Team"
        heading="Operators, capital allocators, and policy architects."
        subheading="Built by people who have done it before — across climate, finance, and sovereign institutions."
      />
      <TeamPlaceholder members={teamMembers} />
      <div class="text-center mt-10">
        <a href="/team" class="btn-secondary text-sm">
          Full team →
        </a>
      </div>
    </div>
  </section>

  <!-- 8. CLOSING CTA -->
  <section class="section-py bg-charcoal relative overflow-hidden">
    <div class="absolute inset-0 opacity-30" aria-hidden="true">
      <div class="absolute inset-0 bg-gradient-to-br from-forest-900 to-charcoal"></div>
    </div>
    <div class="relative section-container text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-lime-DEFAULT mb-4">Act Now</p>
      <h2 class="font-serif text-3xl md:text-5xl font-bold text-white mb-6 max-w-3xl mx-auto leading-tight">
        India's climate transition is entering its make-or-break window.
      </h2>
      <p class="text-white/60 text-base md:text-lg mb-10 max-w-xl mx-auto">
        Partner with India's first full-stack climate platform.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn-primary">
          Investor Enquiry
        </a>
        <a href="mailto:investors@parinama.com" class="btn-ghost">
          Request data room
        </a>
      </div>
      <p class="mt-8 text-white/40 text-sm">
        <a href="mailto:investors@parinama.com" class="hover:text-white/70 transition-colors">
          investors@parinama.com
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
