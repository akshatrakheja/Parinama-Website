---
interface Props {
  eyebrow?: string;
  heading: string;
  subheading?: string;
  align?: 'left' | 'center';
  theme?: 'light' | 'dark';
}

const {
  eyebrow,
  heading,
  subheading,
  align = 'center',
  theme = 'light',
} = Astro.props;

const alignClass = align === 'center' ? 'text-center mx-auto' : 'text-left';
const headingColor = theme === 'dark' ? 'text-white' : 'text-charcoal';
const eyebrowColor = theme === 'dark' ? 'text-lime-DEFAULT' : 'text-forest';
const subColor = theme === 'dark' ? 'text-white/60' : 'text-charcoal/60';
---

<div class={`max-w-2xl mb-12 md:mb-16 ${alignClass}`}>
  {eyebrow && (
    <p class={`text-xs font-semibold uppercase tracking-widest mb-3 ${eyebrowColor}`}>
      {eyebrow}
    </p>
  )}
  <h2 class={`font-serif text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4 ${headingColor}`}>
    {heading}
  </h2>
  {subheading && (
    <p class={`text-base md:text-lg leading-relaxed ${subColor}`}>
      {subheading}
    </p>
  )}
</div>
