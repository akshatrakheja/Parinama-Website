---
const navLinks = [
  { label: 'Home',       href: '/' },
  { label: 'Ethos',      href: '/ethos' },
  { label: 'About',      href: '/about' },
  { label: 'Investors',  href: '/investors' },
];
---

<header class="fixed top-0 inset-x-0 z-40 bg-cream border-b border-black">
  <div class="section-container">
    <nav class="flex items-center justify-between h-12">

      <!-- Logo - plain text only -->
      <a href="/" class="font-display font-bold text-base text-black tracking-tight hover:text-forest transition-colors" aria-label="Parinama Home">
        Parinama
      </a>

      <!-- Right side: Contact Us + Hamburger -->
      <div class="flex items-center gap-6">
        <a href="/contact" class="text-sm font-display font-medium text-black hover:text-forest transition-colors">
          Contact Us
        </a>
        
        <!-- Hamburger button (visible on all screen sizes) -->
        <button
          id="mobile-menu-btn"
          class="p-2 text-black hover:text-forest transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Full-screen drawer menu -->
  <div 
    id="mobile-menu" 
    class="hidden fixed inset-0 bg-forest z-50 transition-opacity duration-300"
  >
    <div class="h-full flex flex-col">
      <!-- Header with close button -->
      <div class="section-container border-b border-gold/20">
        <div class="flex items-center justify-between h-12">
          <a href="/" class="font-display font-bold text-base text-gold" aria-label="Parinama Home">
            Parinama
          </a>
          <button
            id="close-menu-btn"
            class="p-2 text-gold hover:text-gold-light transition-colors"
            aria-label="Close menu"
          >
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Navigation links -->
      <div class="section-container flex-1 flex flex-col justify-center py-12">
        <nav class="space-y-2">
          {navLinks.map(link => (
            <a
              href={link.href}
              class="block py-3 text-4xl md:text-5xl lg:text-6xl font-display font-bold text-gold hover:text-gold-light transition-colors leading-tight"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Footer info -->
      <div class="section-container border-t border-gold/20 py-6">
        <p class="text-sm font-sans text-gold/60">
          Interested in working with us?
        </p>
        <a href="mailto:investors@parinama.com" class="text-base font-display font-semibold text-gold hover:text-gold-light transition-colors">
          investors@parinama.com
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('close-menu-btn');
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    menu?.classList.remove('hidden');
    btn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden'; // Prevent scrolling when menu is open
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = ''; // Restore scrolling
  }

  btn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Close menu when clicking a link
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close menu on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      closeMenu();
    }
  });
</script>
