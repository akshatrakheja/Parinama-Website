---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatStrip from '../components/StatStrip.astro';
---
<BaseLayout title="Contact — Parinama">
  <div class="pt-32 pb-16 section-container text-center">
    <p class="text-xs font-semibold uppercase tracking-widest text-forest mb-4">Get in touch</p>
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-charcoal mb-6 max-w-xl mx-auto leading-tight">
      Join India's climate transformation.
    </h1>
    <p class="text-charcoal/60 mb-8 max-w-md mx-auto">
      For investor enquiries, data room requests, or partnership discussions.
    </p>
    <a href="mailto:investors@parinama.com" class="btn-primary text-base px-8 py-4">
      investors@parinama.com
    </a>
    <p class="mt-8 text-xs text-charcoal/30 max-w-lg mx-auto leading-relaxed">
      For informational purposes only. Does not constitute an offer to buy or sell securities. Subject to SEBI AIF Regulations 2012.
    </p>
  </div>
  <StatStrip />
</BaseLayout>
