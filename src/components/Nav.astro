---
const navLinks = [
  { label: 'Platform',   href: '/platform' },
  { label: 'The Fund',   href: '/fund' },
  { label: 'Ecosystem',  href: '/ecosystem' },
  { label: 'Team',       href: '/team' },
  { label: 'Contact',    href: '/contact' },
];
---

<header class="fixed top-0 inset-x-0 z-50 bg-cream border-b border-black">
  <div class="section-container">
    <nav class="flex items-center justify-between h-14">

      <!-- Logo - plain text only -->
      <a href="/" class="font-display font-bold text-base text-black tracking-tight hover:text-forest transition-colors" aria-label="Parinama Home">
        Parinama
      </a>

      <!-- Right side: Contact Us + Hamburger -->
      <div class="flex items-center gap-6">
        <a href="/contact" class="text-sm font-display font-medium text-black hover:text-forest transition-colors">
          Contact Us
        </a>
        
        <!-- Hamburger button (visible on all screen sizes) -->
        <button
          id="mobile-menu-btn"
          class="p-2 text-black hover:text-forest transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path id="menu-open" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            <path id="menu-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Drawer menu (for all screen sizes) -->
  <div id="mobile-menu" class="hidden border-t border-black bg-cream">
    <div class="section-container py-6 flex flex-col gap-0">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="py-3 text-sm font-display font-medium text-black/70 hover:text-black border-b border-black/10 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const open = document.getElementById('menu-open');
  const close = document.getElementById('menu-close');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    open?.classList.toggle('hidden');
    close?.classList.toggle('hidden');
  });
</script>
