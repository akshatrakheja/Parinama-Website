---
const stats = [
  {
    value: '$10.1T',
    label: 'India climate infra need 2030–2070',
    source: 'CEEW-CEF',
  },
  {
    value: '$150M',
    label: 'Target fund size',
    source: 'SEBI Cat-II AIF · Hard cap $200M',
  },
  {
    value: '15–20%',
    label: 'Blended net IRR (USD, post-fees)',
    source: 'Target return',
  },
  {
    value: '40+',
    label: 'Institutional partners engaged',
    source: 'Aligned & active',
  },
];
---

<style>
  .stat-row {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  @media (min-width: 768px) {
    .stat-row {
      display: grid;
      grid-template-columns: 270px 1fr 12px;
      align-items: start;
      gap: 0 2rem;
    }
  }
</style>

<section class="bg-cream section-container py-0">
  <hr class="border-t border-black w-full" />

  <div class="editorial-grid py-0">
    <!-- Left label -->
    <div class="pt-10 md:pt-12">
      <span class="font-display text-sm text-black">Numbers:</span>
    </div>

    <!-- Right: stat rows in a 3-column sub-grid so descriptions always align -->
    <div>
      {stats.map((stat, i) => (
        <>
          <!--
            3 columns:
              [number — fixed 240px]  [description — flex]  [dot — 12px]
            Fixed number width means descriptions always start at the same x
            regardless of whether the number is "40+" or "$10.1T"
          -->
          <!-- Mobile: stacked. Desktop: 3-column tabular layout -->
          <div class="py-6 md:py-10 stat-row">
            <div class="font-display font-normal text-black leading-none"
                 style="font-size: clamp(2.5rem, 5vw, 7rem); letter-spacing: -0.05em;">
              {stat.value}
            </div>

            <div class="pt-2 md:pt-1">
              <p class="font-sans text-black text-sm md:text-base leading-snug">
                {stat.label}
              </p>
              <p class="font-sans text-black/40 text-xs uppercase tracking-widest mt-1.5">
                {stat.source}
              </p>
            </div>

            <div class="w-2 h-2 rounded-full bg-black mt-2 flex-shrink-0 hidden md:block"></div>
          </div>

          {i < stats.length - 1 && (
            <hr class="border-t border-black/10 w-full" />
          )}
        </>
      ))}
    </div>
  </div>

  <hr class="border-t border-black w-full" />
</section>
