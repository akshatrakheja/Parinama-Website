---
const stats = [
  {
    value: '$10.1T',
    label: 'India climate infra need 2030–2070',
    source: 'CEEW-CEF',
  },
  {
    value: '$150M',
    label: 'Target fund size',
    source: 'SEBI Cat-II AIF · Hard cap $200M',
  },
  {
    value: '15–20%',
    label: 'Blended net IRR (USD, post-fees)',
    source: 'Target return',
  },
  {
    value: '40+',
    label: 'Institutional partners engaged',
    source: 'Aligned & active',
  },
];
---

<section class="bg-cream section-container py-0">
  <!-- Top rule -->
  <hr class="border-t border-black w-full" />

  <!-- Section header: Numbers label on left -->
  <div class="editorial-grid py-6 md:py-8">
    <div>
      <span class="font-display text-sm text-black">Numbers:</span>
    </div>
    <div>
      <!-- Vertical list of stats -->
      <div class="space-y-0">
        {stats.map((stat, i) => (
          <>
            <div class="flex items-start justify-between gap-4 md:gap-8 py-4 md:py-5">
              <!-- Large number -->
              <div class="flex-shrink-0">
                <div class="font-display font-bold text-4xl md:text-5xl lg:text-6xl text-black leading-none">
                  {stat.value}
                </div>
              </div>
              <!-- Description -->
              <div class="flex-1 pt-1">
                <p class="text-black text-sm md:text-base font-sans leading-relaxed">
                  {stat.label}
                </p>
                <p class="text-black/40 text-xs font-sans uppercase tracking-wide mt-1">
                  {stat.source}
                </p>
              </div>
              <!-- Bullet -->
              <span class="w-2 h-2 rounded-full bg-black mt-2 flex-shrink-0"></span>
            </div>
            {i < stats.length - 1 && (
              <hr class="border-t border-black/10 w-full" />
            )}
          </>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom rule -->
  <hr class="border-t border-black w-full" />
</section>
