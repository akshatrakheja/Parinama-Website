---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatStrip from '../components/StatStrip.astro';
import SectionHeader from '../components/SectionHeader.astro';
import NatureGlyph from '../components/NatureGlyph.astro';

const platformRows = [
  {
    name: 'Venture Builder',
    desc: 'Start the companies India needs.',
    detail: '2% management fee + 20% carry, Impact-NAV accounting.',
    metric: '3 active investments',
  },
  {
    name: 'Advisory & JV',
    desc: 'Engineer transition pathways for corporates, sovereigns, DFIs.',
    detail: 'Retainer + success fee + JV equity share.',
    metric: '2 engaged, 3 near close',
  },
  {
    name: 'Ecosystem Architect',
    desc: 'Convene ICIC, deliver via ICIITE.',
    detail: 'Philanthropic + GoI grant funding.',
    metric: 'ICIC + ICIITE in pilot',
  },
];

const moats = [
  {
    name: 'Full-Stack Platform',
    desc: 'Most climate funds deploy capital. Parinama architects the entire system — from seed investment to corporate advisory to ecosystem governance. By owning all three levers simultaneously, we eliminate handoffs, compress the time from insight to impact, and capture value at every layer of the transition.',
  },
  {
    name: 'Institutional Pedigree',
    desc: 'Our partners have built and exited climate businesses, structured DFI mandates, and sat on both sides of the LP–GP table. This is operating experience — not academic thesis. We know what it takes to build in India\'s regulatory and capital environment, and we have the networks to open doors that capital alone cannot.',
  },
  {
    name: 'Sovereign Signal',
    desc: 'India\'s climate transition is a $2.8 trillion national priority. Parinama is built in alignment with this agenda — working alongside GoI institutions, accessing policy infrastructure, and positioning portfolio companies where sovereign tailwinds accelerate both adoption and returns.',
  },
  {
    name: 'Builder-LP Duality',
    desc: 'Parinama is simultaneously a fund manager and a company builder. Our portfolio companies are not just financial bets — they are entities we incubate, staff, and scale. The fund participates in value it directly helps create, aligning incentives in a way a passive allocator never can.',
  },
  {
    name: 'Blended Capital',
    desc: 'Not all climate infrastructure can be funded by equity alone. Our platform stacks philanthropic grants, DFI concessional debt, government incentives, and private equity into single investment vehicles — making deal sizes and return profiles viable across asset classes and risk appetites.',
  },
  {
    name: 'Impact-NAV',
    desc: 'We developed Impact-NAV, a proprietary valuation framework that adjusts portfolio value for climate additionality, carbon intensity reduction, and transition risk. LPs receive a dual-lens view — rigorous financial returns alongside a principled accounting of real-world climate impact.',
  },
];

const fundRows = [
  { label: 'Structure',    value: 'SEBI Cat-II AIF + Singapore VCC feeder + evergreen' },
  { label: 'Target size',  value: '$150M (hard cap $200M TBD)' },
  { label: 'First close',  value: 'Q4 2026 · $50M anchor committed' },
  { label: 'Ticket size',  value: '$1M – $10M per LP' },
  { label: 'Strategy',     value: 'Climate-only · Pre-seed → Series A' },
  { label: 'Target IRR',   value: '15–20% blended net (USD, post-fees)' },
];

const ecosystemRows = [
  {
    name: 'ICIC',
    desc: 'India Climate Investors Council — the convening table. Investor-led governance with 8 active working groups.',
    tags: ['Investor-led', 'Governance body', '8 working groups'],
  },
  {
    name: 'ICIITE',
    desc: 'The delivery engine: accelerator → FOAK → blended finance → scale → MRV.',
    tags: ['Accelerator', 'FOAK financing', 'Blended finance', 'MRV'],
  },
];

const teamMembers = [
  { name: 'Guneet Banga',     role: 'Founding Partner' },
  { name: 'Rajiv P Kapahi',   role: 'Founding Partner' },
  { name: 'Amarjeet Makhija', role: 'Founding Partner' },
  { name: 'Audrey N. Selian', role: 'Advisor' },
];
---

<BaseLayout>

  <!-- ═══════════════════════════════════════════════════════
       HERO — full viewport, 1fr / 3fr axis
  ═══════════════════════════════════════════════════════ -->
  <section class="relative h-screen min-h-[640px] overflow-hidden bg-forest">

    <!-- BACKGROUND VIDEO — drop your Pexels file at public/hero.mp4 -->
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/hero-poster.jpg"
      aria-hidden="true"
    >
      <source src="/hero.mp4" type="video/mp4" />
    </video>

    <!-- FOREST GREEN TINT OVERLAY -->
    <div class="absolute inset-0 bg-forest/60 mix-blend-multiply" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-forest/40 via-transparent to-forest/70" aria-hidden="true"></div>

    <!-- CONTENT LAYER -->
    <div class="relative z-10 h-full flex flex-col justify-between">

      <!-- TOP: heading spans ALL columns -->
      <div class="section-container pt-20 md:pt-28">
        <h1 class="font-display font-normal text-cream leading-none"
            style="font-size: clamp(4rem, 10vw, 12rem); letter-spacing: -0.05em;">
          Capital with<br/>a Conscience.
        </h1>
        <div class="border-t border-white/20 mt-6 pt-4 flex items-center justify-between">
          <span class="text-xs font-sans text-white/50 tracking-wide">Parinama © 2026</span>
          <span class="w-1.5 h-1.5 rounded-full bg-white/40"></span>
        </div>
      </div>

      <!-- BOTTOM: label in left 1fr, tagline + CTA in right 3fr -->
      <div class="section-container pb-14 md:pb-20">
        <div style="display:grid;grid-template-columns:1fr 3fr;gap:0;align-items:end;">
          <div>
            <p class="text-xs font-sans text-gold-DEFAULT uppercase tracking-widest">Who we are:</p>
          </div>
          <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6"
               style="border-left:1px solid rgb(255 255 255/0.2);padding-left:2rem;">
            <p class="font-sans text-cream font-normal leading-snug max-w-xl"
               style="font-size: clamp(1.5rem, 3vw, 2rem); letter-spacing: -0.05em;">
              Architecting and financing India's <span class="hl-sage">climate transition.</span>
              Deploying <span class="hl-gold">principled, patient capital</span> into technologies that reshape energy production and consumption.
            </p>
            <a href="/contact" class="btn-ghost flex-shrink-0 text-base font-semibold">
              Invest with us →
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       STAT STRIP (Section 0 — always visible)
  ═══════════════════════════════════════════════════════ -->
  <StatStrip />


  <!-- ═══════════════════════════════════════════════════════
       SECTION 1 — THE PLATFORM
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-cream section-container py-0">
    <SectionHeader
      number={1}
      title="The Platform"
      leftLabel="Pillar"
      rightLabel="What we do"
    />

    <!-- Content rows -->
    <div>
      {platformRows.map((row, i) => (
        <div class={`editorial-grid py-8 md:py-12 ${i < platformRows.length - 1 ? 'border-b border-black/10' : ''}`}>
          <div class="pt-0.5">
            <span class="text-xs font-sans text-black/30 tabular-nums">0{i + 1}</span>
          </div>
          <div class="flex flex-col md:flex-row gap-4 md:gap-8">
            <div class="md:w-40 flex-shrink-0">
              <p class="font-display font-semibold text-forest text-sm leading-snug">
                {row.name}
              </p>
            </div>
            <div class="flex-1">
              <p class="font-sans text-black text-sm leading-relaxed mb-1">
                {row.desc}
              </p>
              <p class="font-sans text-black/50 text-xs leading-relaxed mb-2">
                {row.detail}
              </p>
              <span class="text-xs font-semibold text-gold-DEFAULT uppercase tracking-wide">
                {row.metric}
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Closing tagline + CTA -->
    <div class="editorial-grid py-10 md:py-14 border-t border-black/10">
      <div></div>
      <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-12">
        <p class="font-display font-bold text-forest text-lg md:text-xl max-w-sm leading-snug">
          Three businesses. <span class="hl-sage">One goal.</span> A <span class="hl-gold">platform — not a portfolio.</span>
        </p>
        <a href="/platform" class="btn-primary self-start">
          Full platform detail →
        </a>
      </div>
    </div>

    <hr class="border-t border-black" />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 2 — SIX MOATS  (interactive accordion)
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-cream section-container py-0">
    <SectionHeader
      number={2}
      title="Six Moats"
      leftLabel="Moat"
      rightLabel="Why it matters"
      leftLabelClass="w-[38%]"
    />

    <!-- editorial-grid: left 1fr label | right 3fr interactive panel -->
    <div class="editorial-grid py-0">
      <div class="pt-8 pb-16">
        <span class="text-xs font-sans text-forest uppercase tracking-widest">Moats:</span>
        <NatureGlyph variant="contour" class="mt-10 mr-10 w-32 md:w-40 h-auto" />
      </div>

      <!-- Right 3fr: two-column interactive panel -->
      <div class="flex min-h-[28rem] py-0">

        <!-- Clickable list — ~38% of the right column, border-r acts as divider -->
        <div class="w-[38%] border-r border-black/10 flex-shrink-0">
          {moats.map((moat, i) => {
            const colors = ['#77C788','#D19900','#77C788','#D19900','#77C788','#D19900'];
            return (
              <button
                class="moat-tab group w-full text-left border-b border-black/10 py-5 pr-8 flex items-start gap-3 transition-all duration-150"
                data-idx={String(i)}
                data-desc={moat.desc}
                data-color={colors[i]}
              >
                <span class="text-[10px] font-mono text-black/25 tabular-nums mt-1 flex-shrink-0 leading-none">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span
                  class="moat-tab-label font-display font-semibold leading-tight text-black/40 group-hover:text-black transition-colors duration-150"
                  style="font-size: clamp(1rem, 1.5vw, 1.35rem);"
                >
                  {moat.name}
                </span>
              </button>
            );
          })}
        </div>

        <!-- Description panel — fills remaining ~62% -->
        <div class="flex-1 pl-10 md:pl-14 pt-5 pb-10">
          <p
            id="moat-panel"
            class="font-sans text-black leading-relaxed transition-opacity duration-200"
            style="font-size: clamp(1rem, 1.4vw, 1.3rem); max-width: 52ch;"
          >
            {moats[0].desc}
          </p>
        </div>
      </div>
    </div>

    <hr class="border-t border-black" />
  </section>

  <script>
    const tabs  = document.querySelectorAll<HTMLButtonElement>('.moat-tab');
    const panel = document.getElementById('moat-panel') as HTMLElement;

    function activate(idx: number) {
      tabs.forEach((tab, i) => {
        const label = tab.querySelector('.moat-tab-label') as HTMLElement | null;
        if (!label) return;
        const color = (tab as HTMLElement).dataset.color ?? '';
        if (i === idx) {
          // Active: highlight background + black text
          (tab as HTMLElement).style.backgroundColor = color;
          (tab as HTMLElement).style.paddingLeft = '0.75rem';
          label.style.color = 'rgb(0 0 0)';
          label.style.opacity = '1';
        } else {
          // Inactive: no background
          (tab as HTMLElement).style.backgroundColor = '';
          (tab as HTMLElement).style.paddingLeft = '';
          label.style.color = '';
          label.style.opacity = '0.35';
        }
      });

      const desc = tabs[idx]?.dataset.desc ?? '';
      panel.style.opacity = '0';
      setTimeout(() => {
        panel.textContent = desc;
        panel.style.opacity = '1';
      }, 140);
    }

    tabs.forEach((tab, i) => tab.addEventListener('click', () => activate(i)));
    activate(0);
  </script>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 3 — THE FUND
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-cream section-container py-0">
    <SectionHeader
      number={3}
      title="The Fund"
      leftLabel=""
      rightLabel=""
    />

    <!-- Fund terms — two-column label/value grid -->
    <div class="editorial-grid py-8 md:py-12">
      <div>
        <span class="text-xs font-sans text-forest uppercase tracking-widest">Terms:</span>
        <NatureGlyph variant="flow" class="mt-10 mr-10 w-32 md:w-40 h-auto" />
      </div>

      <div>
        <!-- Eyebrow + CTA row -->
        <div class="flex items-start justify-between gap-6 mb-8 md:mb-10">
          <p class="text-xs font-sans text-forest uppercase tracking-widest pt-1">
            Climate fund at a glance
          </p>
          <a href="/fund" class="btn-secondary self-start flex-shrink-0">
            Full fund details →
          </a>
        </div>

        <!-- Two-column terms grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 lg:gap-x-20">
          {fundRows.map((row) => (
            <div class="flex items-baseline gap-6 py-4 border-b border-black/10">
              <span class="w-32 md:w-36 flex-shrink-0 text-xs font-sans text-forest uppercase tracking-widest">
                {row.label}
              </span>
              <span class="flex-1 font-sans text-black text-sm leading-relaxed">
                {row.value}
              </span>
            </div>
          ))}
        </div>

        <!-- Footnote -->
        <p class="text-xs text-black/40 font-sans leading-relaxed mt-8 max-w-xl">
          For informational purposes only. Does not constitute an offer to buy or sell securities. Subject to SEBI AIF Regulations 2012.
        </p>
      </div>
    </div>

    <hr class="border-t border-black" />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 4 — ECOSYSTEM
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-cream section-container py-0">
    <SectionHeader
      number={4}
      title="The Ecosystem"
      leftLabel="Body"
      rightLabel="Role"
    />

    <div>
      {ecosystemRows.map((row, i) => (
        <div class={`editorial-grid py-10 md:py-14 ${i < ecosystemRows.length - 1 ? 'border-b border-black/10' : ''}`}>
          <div class="pt-0.5">
            <span class="text-xs font-sans text-black/30 tabular-nums">0{i + 1}</span>
          </div>
          <div class="flex flex-col md:flex-row gap-4 md:gap-8">
            <div class="md:w-40 flex-shrink-0">
              <p class="font-display font-bold text-forest text-xl md:text-2xl leading-none">
                {row.name}
              </p>
            </div>
            <div class="flex-1">
              <p class="font-sans text-black text-sm leading-relaxed mb-3">{row.desc}</p>
              <div class="flex flex-wrap gap-2">
                {row.tags.map(tag => (
                  <span class="text-xs font-sans border border-black/20 text-black/60 px-2 py-0.5">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- 4P architecture -->
    <div class="editorial-grid py-10 md:py-14 border-t border-black/10">
      <div></div>
      <div class="flex flex-col gap-3">
        <p class="text-xs font-sans text-forest uppercase tracking-widest">Backed by the 4P Architecture</p>
        <div class="flex flex-wrap gap-6">
          {['Public', 'Private', 'Philanthropic', 'People'].map(p => (
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-sage-DEFAULT flex-shrink-0"></span>
              <span class="font-display font-semibold text-sm text-black">{p}</span>
            </div>
          ))}
        </div>
        <a href="/ecosystem" class="btn-secondary self-start mt-2">
          Explore ecosystem →
        </a>
      </div>
    </div>

    <hr class="border-t border-black" />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 5 — TEAM  (4-column photo grid)
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-cream section-container py-0">
    <SectionHeader
      number={5}
      title="The Team"
      leftLabel=""
      rightLabel=""
    />

    <!-- Full-width 4-column photo strip — no grid offset, edge to edge -->
    <div class="overflow-x-auto">
      <div class="flex md:grid md:grid-cols-4 min-w-max md:min-w-0">
        {teamMembers.map((member) => (
          <div class="w-64 md:w-auto flex-shrink-0 border-l border-black/10 first:border-l-0 flex flex-col">
            <!-- Photo placeholder — replace inner div with <img> when ready -->
            <div class="bg-black/5 w-full flex items-center justify-center"
                 style="aspect-ratio: 3/4;">
              <svg class="w-10 h-10 text-black/15" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <!-- Name + role -->
            <div class="px-4 pt-4 pb-8">
              <p class="font-display font-semibold text-black text-sm leading-snug mb-0.5">
                {member.name}
              </p>
              <p class="font-sans text-black/40 text-xs tracking-wide">{member.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="py-6 border-t border-black/10 flex flex-col md:flex-row md:items-center gap-4 md:gap-12">
      <p class="font-sans text-forest text-xs uppercase tracking-widest">
        Operators · Capital allocators · Policy architects
      </p>
      <a href="/team" class="btn-secondary self-start">Full team →</a>
    </div>

    <hr class="border-t border-black" />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 6 — CLOSING CTA
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-forest text-white">
    <div class="section-container py-0">

      <hr class="border-t border-white/20" />

      <div class="editorial-grid items-start py-16 md:py-28">
        <div class="pt-1">
          <span class="inline-block bg-white text-forest font-display font-bold text-xs px-2 py-1 leading-none">6:</span>
        </div>
        <div>
          <h2 class="font-display font-bold text-white text-3xl md:text-5xl lg:text-6xl leading-tight mb-3 tracking-tight max-w-2xl">
            India's climate transition is entering its
            make-or-break window.
          </h2>
          <p class="font-sans text-white/60 text-sm md:text-base mb-4 max-w-md">
            Partner with India's first full-stack climate platform.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 mb-8">
            <a href="/contact" class="btn-ghost">
              Investor Enquiry →
            </a>
            <a href="mailto:investors@parinama.com" class="inline-flex items-center justify-center px-6 py-3 text-white/60 font-display font-semibold text-sm tracking-wide hover:text-white transition-colors">
              Request data room →
            </a>
          </div>
          <p class="text-white/30 text-xs font-sans">
            <a href="mailto:investors@parinama.com" class="hover:text-white/60 transition-colors">
              investors@parinama.com
            </a>
          </p>
        </div>
      </div>

      <hr class="border-t border-white/20" />
    </div>
  </section>

</BaseLayout>
