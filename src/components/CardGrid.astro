---
interface Card {
  title: string;
  tagline: string;
  detail?: string;
  metric?: string;
  href?: string;
  icon?: string;
}

interface Props {
  cards: Card[];
  columns?: 2 | 3 | 6;
}

const { cards, columns = 3 } = Astro.props;

const gridClass = {
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-3',
  6: 'grid-cols-2 md:grid-cols-3 lg:grid-cols-6',
}[columns];
---

<div class={`grid ${gridClass} gap-6`}>
  {cards.map(card => (
    <div class="group relative bg-white rounded-2xl p-6 border border-forest/10 hover:border-forest/30 hover:shadow-xl transition-all duration-300">
      {card.icon && (
        <div class="w-10 h-10 rounded-xl bg-forest/10 flex items-center justify-center mb-4 group-hover:bg-forest group-hover:text-white transition-colors text-forest text-lg">
          {card.icon}
        </div>
      )}
      <h3 class="font-serif text-lg font-semibold text-charcoal mb-2 leading-snug">
        {card.title}
      </h3>
      <p class="text-sm text-charcoal/60 leading-relaxed mb-3">{card.tagline}</p>
      {card.detail && (
        <p class="text-xs text-charcoal/40 leading-relaxed border-t border-forest/5 pt-3">{card.detail}</p>
      )}
      {card.metric && (
        <div class="mt-3 text-xs font-semibold text-forest bg-forest/5 rounded-full px-3 py-1 inline-block">
          {card.metric}
        </div>
      )}
      {card.href && (
        <a href={card.href} class="absolute inset-0 rounded-2xl" aria-label={`Learn more about ${card.title}`} />
      )}
    </div>
  ))}
</div>
