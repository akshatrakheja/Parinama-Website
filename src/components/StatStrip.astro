---
const stats = [
  {
    value: '$10.1T',
    label: 'India climate infra need 2030–2070',
    source: 'CEEW-CEF',
  },
  {
    value: '$150M',
    label: 'Target fund size',
    source: 'SEBI Cat-II AIF · Hard cap $200M',
  },
  {
    value: '15–20%',
    label: 'Blended net IRR (USD, post-fees)',
    source: 'Target return',
  },
  {
    value: '40+',
    label: 'Institutional partners engaged',
    source: 'Aligned & active',
  },
];
---

<section class="bg-black text-white">
  <div class="section-container">
    <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-white/10">
      {stats.map((stat) => (
        <div class="px-6 py-8 md:py-10">
          <div class="font-display font-bold text-2xl md:text-3xl text-gold-DEFAULT leading-none mb-2">
            {stat.value}
          </div>
          <div class="text-xs font-sans text-white/70 leading-snug mb-1">{stat.label}</div>
          <div class="text-xs font-sans text-white/30 uppercase tracking-wide">{stat.source}</div>
        </div>
      ))}
    </div>
  </div>
</section>
