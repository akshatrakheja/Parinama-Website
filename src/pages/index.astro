---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatStrip from '../components/StatStrip.astro';
import SectionHeader from '../components/SectionHeader.astro';

const platformRows = [
  {
    name: 'Venture Builder',
    desc: 'Start the companies India needs.',
    detail: '2% management fee + 20% carry, Impact-NAV accounting.',
    metric: '3 active investments',
  },
  {
    name: 'Advisory & JV',
    desc: 'Engineer transition pathways for corporates, sovereigns, DFIs.',
    detail: 'Retainer + success fee + JV equity share.',
    metric: '2 engaged, 3 near close',
  },
  {
    name: 'Ecosystem Architect',
    desc: 'Convene ICIC, deliver via ICIITE.',
    detail: 'Philanthropic + GoI grant funding.',
    metric: 'ICIC + ICIITE in pilot',
  },
];

const moats = [
  { name: 'Full-Stack Platform',    desc: 'End-to-end: capital → advisory → ecosystem.' },
  { name: 'Institutional Pedigree', desc: 'Operators and allocators, not just advisors.' },
  { name: 'Sovereign Signal',       desc: 'Aligned with national climate transition agenda.' },
  { name: 'Builder-LP Duality',     desc: 'We build companies and invest in them.' },
  { name: 'Blended Capital',        desc: 'Public + private + philanthropic stacks.' },
  { name: 'Impact-NAV',             desc: 'Proprietary impact-adjusted valuation model.' },
];

const fundRows = [
  { label: 'Structure',    value: 'SEBI Cat-II AIF + Singapore VCC feeder + evergreen' },
  { label: 'Target size',  value: '$150M (hard cap $200M TBD)' },
  { label: 'First close',  value: 'Q4 2026 · $50M anchor committed' },
  { label: 'Ticket size',  value: '$1M – $10M per LP' },
  { label: 'Strategy',     value: 'Climate-only · Pre-seed → Series A' },
  { label: 'Target IRR',   value: '15–20% blended net (USD, post-fees)' },
];

const ecosystemRows = [
  {
    name: 'ICIC',
    desc: 'India Climate Investors Council — the convening table. Investor-led governance with 8 active working groups.',
    tags: ['Investor-led', 'Governance body', '8 working groups'],
  },
  {
    name: 'ICIITE',
    desc: 'The delivery engine: accelerator → FOAK → blended finance → scale → MRV.',
    tags: ['Accelerator', 'FOAK financing', 'Blended finance', 'MRV'],
  },
];

const teamMembers = [
  { name: 'Guneet Banga',     role: 'Founding Partner' },
  { name: 'Rajiv P Kapahi',   role: 'Founding Partner' },
  { name: 'Amarjeet Makhija', role: 'Founding Partner' },
  { name: 'Audrey N. Selian', role: 'Advisor' },
];
---

<BaseLayout>

  <!-- ═══════════════════════════════════════════════════════
       SECTION 0 — INTRO
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-cream section-container py-0">
    <!-- Top rule -->
    <hr class="border-t border-black w-full" />

    <!-- Section header -->
    <div class="editorial-grid items-start py-6 md:py-8">
      <div class="pt-1">
        <span class="font-display text-sm text-black">Intro:</span>
      </div>
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <p class="text-black/40 text-xs font-sans uppercase tracking-widest mb-4">
            SEBI Cat-II AIF · First close Q4 2026
          </p>
          <h1 class="font-display font-bold leading-none tracking-tight text-4xl md:text-6xl lg:text-7xl mb-6 text-black">
            India's climate<br/>
            <span class="text-gold-DEFAULT">transformation</span><br/>
            is the investment.
          </h1>
          <p class="text-black text-base md:text-lg max-w-2xl mb-2 font-sans leading-relaxed">
            India's first full-stack climate platform —
            <span class="text-sage-DEFAULT font-semibold">AIF · Advisory · Ecosystem.</span>
          </p>
          <p class="text-black/60 text-sm max-w-xl mb-8 font-sans leading-relaxed">
            India's climate transformation is underway. This is the entry point.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/contact" class="btn-primary">
              Investor Enquiry →
            </a>
            <a href="/platform" class="btn-secondary">
              Explore the Platform
            </a>
          </div>
        </div>
        <span class="w-2 h-2 rounded-full bg-black mt-3 flex-shrink-0"></span>
      </div>
    </div>

    <!-- Bottom rule -->
    <hr class="border-t border-black w-full" />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       STAT STRIP (Section 0 — always visible)
  ═══════════════════════════════════════════════════════ -->
  <StatStrip />


  <!-- ═══════════════════════════════════════════════════════
       SECTION 1 — THE PLATFORM
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-cream section-container py-0">
    <SectionHeader
      number={1}
      title="The Platform"
      leftLabel="Pillar"
      rightLabel="What we do"
    />

    <!-- Content rows -->
    <div>
      {platformRows.map((row, i) => (
        <div class={`editorial-grid py-6 md:py-8 ${i < platformRows.length - 1 ? 'border-b border-black/10' : ''}`}>
          <div class="pt-0.5">
            <span class="text-xs font-sans text-black/30 tabular-nums">0{i + 1}</span>
          </div>
          <div class="flex flex-col md:flex-row gap-4 md:gap-8">
            <div class="md:w-40 flex-shrink-0">
              <p class="font-display font-semibold text-forest text-sm leading-snug">
                {row.name}
              </p>
            </div>
            <div class="flex-1">
              <p class="font-sans text-black text-sm leading-relaxed mb-1">
                {row.desc}
              </p>
              <p class="font-sans text-black/50 text-xs leading-relaxed mb-2">
                {row.detail}
              </p>
              <span class="text-xs font-semibold text-gold-DEFAULT uppercase tracking-wide">
                {row.metric}
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Closing tagline + CTA -->
    <div class="editorial-grid py-8 border-t border-black/10">
      <div></div>
      <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-12">
        <p class="font-display font-bold text-forest text-lg md:text-xl max-w-sm leading-snug">
          Three businesses. One goal. A platform — not a portfolio.
        </p>
        <a href="/platform" class="btn-primary self-start">
          Full platform detail →
        </a>
      </div>
    </div>

    <hr class="border-t border-black" />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 2 — SIX MOATS
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-cream section-container py-0">
    <SectionHeader
      number={2}
      title="Six Moats"
      leftLabel="Moat"
      rightLabel="Why it matters"
    />

    <div>
      {moats.map((moat, i) => (
        <div class={`editorial-grid py-5 md:py-6 ${i < moats.length - 1 ? 'border-b border-black/10' : ''}`}>
          <div class="pt-0.5">
            <span class="text-xs font-sans text-black/30 tabular-nums">0{i + 1}</span>
          </div>
          <div class="flex flex-col md:flex-row gap-3 md:gap-8">
            <div class="md:w-40 flex-shrink-0">
              <p class="font-display font-semibold text-forest text-sm">{moat.name}</p>
            </div>
            <p class="font-sans text-black text-sm leading-relaxed flex-1">{moat.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <hr class="border-t border-black" />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 3 — THE FUND
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-cream section-container py-0">
    <SectionHeader
      number={3}
      title="The Fund"
      leftLabel="Parameter"
      rightLabel="Detail"
    />

    <div>
      {fundRows.map((row, i) => (
        <div class={`editorial-grid py-5 md:py-6 ${i < fundRows.length - 1 ? 'border-b border-black/10' : ''}`}>
          <div class="pt-0.5">
            <span class="text-xs font-sans text-black/30 tabular-nums">0{i + 1}</span>
          </div>
          <div class="flex flex-col md:flex-row gap-3 md:gap-8">
            <div class="md:w-40 flex-shrink-0">
              <p class="font-display font-semibold text-black/60 text-sm">{row.label}</p>
            </div>
            <p class="font-sans text-black text-sm leading-relaxed flex-1">
              {row.value}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Disclaimer + CTA -->
    <div class="editorial-grid py-8 border-t border-black/10">
      <div></div>
      <div class="flex flex-col md:flex-row md:items-start gap-6 md:gap-12">
        <p class="text-xs text-black/40 font-sans max-w-sm leading-relaxed">
          For informational purposes only. Does not constitute an offer to buy or sell securities. Subject to SEBI AIF Regulations 2012.
        </p>
        <a href="/fund" class="btn-primary self-start">
          Full fund details →
        </a>
      </div>
    </div>

    <hr class="border-t border-black" />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 4 — ECOSYSTEM
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-cream section-container py-0">
    <SectionHeader
      number={4}
      title="The Ecosystem"
      leftLabel="Body"
      rightLabel="Role"
    />

    <div>
      {ecosystemRows.map((row, i) => (
        <div class={`editorial-grid py-6 md:py-8 ${i < ecosystemRows.length - 1 ? 'border-b border-black/10' : ''}`}>
          <div class="pt-0.5">
            <span class="text-xs font-sans text-black/30 tabular-nums">0{i + 1}</span>
          </div>
          <div class="flex flex-col md:flex-row gap-4 md:gap-8">
            <div class="md:w-40 flex-shrink-0">
              <p class="font-display font-bold text-forest text-xl md:text-2xl leading-none">
                {row.name}
              </p>
            </div>
            <div class="flex-1">
              <p class="font-sans text-black text-sm leading-relaxed mb-3">{row.desc}</p>
              <div class="flex flex-wrap gap-2">
                {row.tags.map(tag => (
                  <span class="text-xs font-sans border border-black/20 text-black/60 px-2 py-0.5">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- 4P architecture -->
    <div class="editorial-grid py-6 border-t border-black/10">
      <div></div>
      <div class="flex flex-col gap-3">
        <p class="text-xs font-sans text-black/50 uppercase tracking-widest">Backed by the 4P Architecture</p>
        <div class="flex flex-wrap gap-6">
          {['Public', 'Private', 'Philanthropic', 'People'].map(p => (
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-sage-DEFAULT flex-shrink-0"></span>
              <span class="font-display font-semibold text-sm text-black">{p}</span>
            </div>
          ))}
        </div>
        <a href="/ecosystem" class="btn-secondary self-start mt-2">
          Explore ecosystem →
        </a>
      </div>
    </div>

    <hr class="border-t border-black" />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 5 — TEAM
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-cream section-container py-0">
    <SectionHeader
      number={5}
      title="The Team"
      leftLabel="Name"
      rightLabel="Role"
    />

    <div>
      {teamMembers.map((member, i) => (
        <div class={`editorial-grid py-5 md:py-6 ${i < teamMembers.length - 1 ? 'border-b border-black/10' : ''}`}>
          <div class="pt-0.5">
            <!-- Placeholder avatar -->
            <div class="w-8 h-8 border border-dashed border-black/20 flex items-center justify-center">
              <svg class="w-4 h-4 text-black/20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
          </div>
          <div class="flex flex-col md:flex-row gap-2 md:gap-8">
            <div class="md:w-40 flex-shrink-0">
              <p class="font-display font-semibold text-forest text-sm">{member.name}</p>
            </div>
            <p class="font-sans text-black/60 text-sm">{member.role}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="editorial-grid py-6 border-t border-black/10">
      <div></div>
      <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-12">
        <p class="font-sans text-black/50 text-sm italic">
          Operators, capital allocators, and policy architects.
        </p>
        <a href="/team" class="btn-secondary self-start">
          Full team →
        </a>
      </div>
    </div>

    <hr class="border-t border-black" />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 6 — CLOSING CTA
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-forest text-white">
    <div class="section-container py-0">

      <hr class="border-t border-white/20" />

      <div class="editorial-grid items-start py-10 md:py-16">
        <div class="pt-1">
          <span class="inline-block bg-white text-forest font-display font-bold text-xs px-2 py-1 leading-none">6:</span>
        </div>
        <div>
          <h2 class="font-display font-bold text-white text-3xl md:text-5xl lg:text-6xl leading-tight mb-6 tracking-tight max-w-2xl">
            India's climate transition is entering its
            <span class="text-gold-DEFAULT"> make-or-break window.</span>
          </h2>
          <p class="font-sans text-white/60 text-sm md:text-base mb-8 max-w-md">
            Partner with India's first full-stack climate platform.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 mb-8">
            <a href="/contact" class="btn-ghost">
              Investor Enquiry →
            </a>
            <a href="mailto:investors@parinama.com" class="inline-flex items-center justify-center px-6 py-3 text-white/60 font-display font-semibold text-sm tracking-wide hover:text-white transition-colors">
              Request data room →
            </a>
          </div>
          <p class="text-white/30 text-xs font-sans">
            <a href="mailto:investors@parinama.com" class="hover:text-white/60 transition-colors">
              investors@parinama.com
            </a>
          </p>
        </div>
      </div>

      <hr class="border-t border-white/20" />
    </div>
  </section>

</BaseLayout>
